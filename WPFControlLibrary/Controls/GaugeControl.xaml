<p:BaseUserControl x:Class="WPFControlLibrary.Controls.GaugeControl"  xmlns:p="clr-namespace:WPFControlLibrary.Base"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wpfGauge="clr-namespace:WpfGauge;assembly=WpfGauge"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid IsHitTestVisible="False">
        <Viewbox Name="CalulatedValue" StretchDirection="Both" Grid.Row="1" Stretch="Uniform">
            <wpfGauge:Gauge />
            </Viewbox>
    </Grid>
</p:BaseUserControl>
