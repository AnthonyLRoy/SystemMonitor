<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
    <section name="ExternalReaderLibrary" type="Dan.Client.Monitor.Reader.ExternalReaderLibrarySection, Dan.Client.Monitor.Reader"/>
  </configSections>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
  <appSettings>
    <add key="SB_PUBLISH_FREQUENCY" value ="10000"/>
    <add key="log4net.Internal.Debug" value="true"/>

    <add key="Microsoft.ServiceBus.ConnectionString" value="Endpoint=sb://[your-namespace].servicebus.windows.net/;SharedSecretIssuer=owner;SharedSecretValue=[your-shared-secret]" />
    <add key="QUEUE_NAME" value="monitorevents"/>
    <add key="MONITOR_CONFIG_FILE" value ="Monitor.xml"/>
    <add key="Dan.Client.SQLReader"/>
  </appSettings>
<log4net>
    <appender name="ColoredConsoleAppender" type="log4net.Appender.ColoredConsoleAppender">
      <mapping>
        <level value="ERROR" />
        <foreColor value="White" />
        <backColor value="Red, HighIntensity" />
      </mapping>
      <mapping>
        <level value="DEBUG" />
        <backColor value="Green" />
      </mapping>
      <mapping>
        <level value="INFO" />
        <foreColor value="Green" />
      </mapping>
      <mapping>
        <level value="WARN" />
        <foreColor value="YELLOW" />
      </mapping>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%level]  [%thread]  %message%newline" />
      </layout>
    </appender>
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="c:\temp\ConversionLog.txt" />
      <appendToFile value="true" />
      <rollingStyle value="Size" />
      <maxSizeRollBackups value="5" />
      <maximumFileSize value="5MB" />
      <staticLogFileName value="true" />
      <filter type="log4net.Filter.LevelRangeFilter">
        <levelMin value="INFO" />
        <levelMax value="FATAL" />
      </filter>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%level]  [%thread] %logger - %message%newline" />
      </layout>
    </appender>
    <root>
      <level value="INFO"/>
      <appender-ref ref="ColoredConsoleAppender"/>
      <appender-ref ref="RollingFileAppender"/>
    </root>
  </log4net>
  <ExternalReaderLibrary>
    <libraries>
      <!--<add name="Dan.Client.EventLogReader.dll" location=""/>-->
      <!--<add name="Dan.Client.DirectoryReader.dll" location=""/>-->
      <add name="Dan.Client.PerformanceMonReader.dll" location=""/>

    </libraries>
  </ExternalReaderLibrary>
</configuration>