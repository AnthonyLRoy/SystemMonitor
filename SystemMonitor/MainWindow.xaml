<Window x:Class="SystemMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="700" Width="1024">
    <Grid Name="ControlGrid" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>
        <Menu HorizontalAlignment="Stretch" Name="MainMenu"  Grid.RowSpan="1" VerticalAlignment="Top"   >

        </Menu>
        <!--<Canvas x:Name="MainCanvas" HorizontalAlignment="Stretch"  Grid.Row="1" VerticalAlignment="Stretch" Background="#FF3F443C" Grid.ColumnSpan="2" Margin="3,3,3,3"/>-->
        <StatusBar Grid.Row="2">
            <StatusBarItem Content="Dans monitor"/>
        </StatusBar>
    </Grid>

</Window>

