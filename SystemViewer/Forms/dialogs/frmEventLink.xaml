<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ViewModel="clr-namespace:SystemViewer.ViewModel" x:Class="SystemViewer.Forms.dialogs.frmEventLink"
        Title="Event Mapper" Height="375" Width="496">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="23"/>
            <RowDefinition Height="212*"/>
            <RowDefinition Height="27"/>
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Stretch"  Grid.RowSpan="1" VerticalAlignment="Stretch"/>
        <ComboBox x:Name="CboGroups" HorizontalAlignment="Stretch"  VerticalAlignment="Stretch"  DisplayMemberPath="Groupname" SelectedValuePath="Groupname" SelectionChanged="CboGroups_SelectionChanged">
            <ComboBox.DataContext>
                <ViewModel:EventListViewModel/>
            </ComboBox.DataContext>
        </ComboBox>
        <StackPanel HorizontalAlignment="right"  Grid.Row="2" VerticalAlignment="Stretch" Orientation="Horizontal" >
            <Button x:Name ="CancelButton" Content="Cancel" IsDefault="True" HorizontalAlignment="Center" VerticalAlignment="Center"  Width="75" Margin="0,0,10,0" Click="CancelButton_OnClick"/>
            <Button x:Name="OkButton" Content="OK" HorizontalAlignment="Right"  VerticalAlignment="Center" Width="75" Margin="0,0,10,0" Click="OkButton_OnClick"/>
        </StackPanel>
        <ListBox x:Name="LstEventList"  HorizontalAlignment="Stretch" Grid.Row="1" VerticalAlignment="Stretch" SelectionChanged="LstEventList_SelectionChanged" />
    </Grid>
</Window>
