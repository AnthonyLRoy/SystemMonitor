<Window x:Class="SystemViewer.Forms.dialogs.frmNewDiagram"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Diagram" Height="100" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="52*"/>
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" >
            <Button Content="Create" IsDefault="True" HorizontalAlignment="Center" VerticalAlignment="Center"  Width="75" Margin="0,0,10,0" Click="Button_Click"/>
            <Button Name="CancelButton" Content="Cancel" HorizontalAlignment="Right"  VerticalAlignment="Center" Width="75" Margin="0,0,10,0" Click="CancelButton_OnClick"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Stretch"  Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" >
            <Label Content="New Diagram Name" VerticalAlignment="Center" FontWeight="Bold"/>
           
            <TextBox Name="TxtDiagramName" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Width="158" Background="#FFF6F8FB"/>

        </StackPanel>



    </Grid>
</Window>
