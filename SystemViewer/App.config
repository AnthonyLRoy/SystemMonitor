<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="ExternalReaderLibrary" type="SystemViewer.Config.ExternalReaderLibrarySection,SystemViewer"/>
    <section name="MetricReaderLibrary" type="SystemViewer.Config.MetricReaderLibrarySection,SystemViewer"/>
  </configSections>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
    </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Xceed.Wpf.AvalonDock" publicKeyToken="3e4669d2f30244f4" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-2.2.0.0" newVersion="2.2.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <ExternalReaderLibrary>
    <libraries>
      <add name="WPFControlLibrary.dll" location="" active="true"/>
    </libraries>
  </ExternalReaderLibrary>
<!-- Readers that Read performance counters from a source -->
  <MetricReaderLibrary>
    <readers>
      <add name="WebMetricsReader.dll" location="" active="true"/>
    </readers>
  </MetricReaderLibrary>
  <appSettings>
    <add key="webapibygroup" value="http://statwebapi.cloudapp.net/api/GetStatistics?groupName={0}"/>
    <add key="webapibylist" value ="http://statwebapi.cloudapp.net/api/GetStatistics"/>
    <add key="webapigroups" value="http://statwebapi.cloudapp.net/api/GetReadGroups?filter={0}"/>
  </appSettings>
  <system.diagnostics>
    <sources>
      <source name="System.Windows.Data" switchName="SourceSwitch" >
        <listeners>
          <add name="textListener" />
        </listeners>
      </source>
    </sources>
    <switches>
      <add name="SourceSwitch" value="All" />
    </switches>
    <sharedListeners>
      <add name="textListener"
      type="System.Diagnostics.TextWriterTraceListener"
      initializeData="GraveOfBindErrors.txt" />
    </sharedListeners>
    <trace autoflush="true" indentsize="4"></trace>
  </system.diagnostics>
</configuration>