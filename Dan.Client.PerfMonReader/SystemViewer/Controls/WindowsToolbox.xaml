<UserControl x:Class="SystemViewer.Controls.Windowtoolbox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:toolBox="clr-namespace:SystemViewer.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.DataContext>
        <toolBox:ControlViewlModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <DataTemplate x:Key="toolitem">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Image   Grid.Row="0"  ToolTip="{Binding Description}" Width="50" Height="50">
                    <Image.Source>
                        <BitmapImage UriSource="{Binding IconImage}"/>
                    </Image.Source>
                </Image> 
                <Label Grid.Row="1" Content="{Binding Name}" />

            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <ListBox Name="ListToooBox" PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown" PreviewMouseMove="List_MouseMove" ItemsSource="{Binding DiagramControls}" ItemTemplate="{StaticResource toolitem}" />


</UserControl>


