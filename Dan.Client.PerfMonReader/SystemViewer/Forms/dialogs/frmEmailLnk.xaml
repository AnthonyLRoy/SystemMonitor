<Window x:Class="SystemViewer.Forms.dialogs.frmEmailLnk"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="frmEmailLnk" Height="378" Width="420">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42*"/>
            <RowDefinition Height="245*"/>
            <RowDefinition Height="60*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Manage Email Messages" HorizontalAlignment="stretch" VerticalAlignment="Stretch"/>
        <DataGrid Name="EmailAddresses" HorizontalAlignment="Stretch" Margin="5,10,5,10" Grid.Row="1" VerticalAlignment="Stretch"/>
        <StackPanel HorizontalAlignment="Stretch" Margin="10,10,10,10" Grid.Row="2" VerticalAlignment="stretch" Orientation="Horizontal" >
            <Button Name="AddName"  Content="Add" Margin="10,5,10,5" Width="100"/>
            <Button Name="RemoveName" Content="Remove" Margin="10,5,10,5"  Width="100"/>
            <Button Name ="ApplyChanges" Content="Apply" Margin="10,5,10,5"  Width="100"/>
        </StackPanel>

    </Grid>
</Window>
